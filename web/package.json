    "ai-career-assistant",
    "job-search-automation",
    "ats-resume",
    "ats-cv",
    "resume-builder",
    "cv-generator",
    "job-tracker",
    "applicant-tracking",
    "linkedin-outreach",
    "interview-prep",
    "interview-preparation",
    "claude-ai",
    "anthropic",
    "anthropic-api",
    "claude-sonnet",
    "llm-application",
    "self-hosted",
    "multi-user",
    "open-source",
    "career-tools",
    "job-application-tracker",
    "tailored-cv",
    "tailored-resume",
    "ai-cover-letter",
    "salary-negotiation",
    "rejection-pattern-analyzer",
    "follow-up-tracker",
    "greenhouse",
    "ashby",
    "lever",
    "playwright",
    "express",
    "nodejs"
  ],
  "author": "Punith VT",
  "license": "MIT",
